# .dockerignore for the commit-image build.
# Goal: bake in the FULL repo (including .git history — the grader uses it),
# dropping only local build artifacts and editor/OS cruft. Dev image, not minimal.

# ── Build outputs / local cruft ──────────────────────────────────────────────
# The COPY boundary is what separates source from artifacts. build.sh produces its
# outputs under /mayhem (the amalgamation, objects, fuzzcheck, the shell) at build time.
build/
bld/
out/
mayhem-build/
*.o
*.a
*.so
*.dylib
sqlite3.c
sqlite3.h
**/__pycache__/

# ── Editor / OS noise ────────────────────────────────────────────────────────
.DS_Store
*.swp
*~
